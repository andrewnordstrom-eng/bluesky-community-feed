{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corgi.network/schemas/lab-manifest.schema.json",
  "title": "Corgi Lab Artifact Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "issue",
    "branch",
    "git",
    "command",
    "envAllowlist",
    "runtime",
    "startedAt",
    "endedAt",
    "artifacts",
    "thresholds",
    "claims"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "issue": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["head", "base", "dirtyFiles", "diffSha256"],
      "properties": {
        "head": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "base": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "dirtyFiles": { "type": "array", "items": { "type": "string" } },
        "diffSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argv", "cwd", "exitCode", "stdoutPath", "stderrPath"],
      "properties": {
        "argv": { "type": "array", "items": { "type": "string" } },
        "cwd": { "type": "string", "minLength": 1 },
        "exitCode": { "type": ["integer", "null"] },
        "stdoutPath": { "type": ["string", "null"] },
        "stderrPath": { "type": ["string", "null"] }
      }
    },
    "envAllowlist": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "npm", "platform", "arch", "release", "cpus", "totalMemoryBytes"],
      "properties": {
        "node": { "type": "string", "minLength": 1 },
        "npm": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "minLength": 1 },
        "arch": { "type": "string", "minLength": 1 },
        "release": { "type": "string", "minLength": 1 },
        "cpus": { "type": "integer", "minimum": 1 },
        "totalMemoryBytes": { "type": "integer", "minimum": 1 }
      }
    },
    "startedAt": { "type": "string", "format": "date-time" },
    "endedAt": { "type": "string", "format": "date-time" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "bytes", "mediaType", "producedBy"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "bytes": { "type": "integer", "minimum": 0 },
          "mediaType": { "type": "string", "minLength": 1 },
          "producedBy": { "type": "string", "minLength": 1 }
        }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": true
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "status"],
        "properties": {
          "claim": { "type": "string", "minLength": 1 },
          "status": { "enum": ["pass", "fail", "blocked", "not-run"] },
          "evidencePaths": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "status": { "enum": ["pass", "fail"] }
              },
              "required": ["status"]
            },
            "then": {
              "required": ["evidencePaths"],
              "properties": {
                "evidencePaths": { "minItems": 1 }
              }
            }
          }
        ]
      }
    }
  }
}
