{
  "name": "community-feed",
  "version": "1.0.0",
  "type": "module",
  "description": "A community-governed Bluesky feed generator where subscribers vote on algorithm parameters",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "migrate": "tsx scripts/migrate.ts",
    "stress": "tsx tests/stress/run.ts",
    "generate-feed-did": "tsx scripts/generate-feed-did.ts",
    "publish-feed": "tsx scripts/publish-feed.ts",
    "test": "vitest",
    "generate:component": "tsx scripts/generate-scoring-component.ts",
    "generate:route": "tsx scripts/generate-route.ts",
    "cli": "cd cli && npx tsx src/index.ts",
    "cli:build": "cd cli && tsc",
    "seed-topics": "tsx scripts/seed-topics.ts",
    "backfill-topics": "tsx scripts/backfill-topics.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@atproto/api": "^0.19.3",
    "@atproto/crypto": "^0.4.0",
    "@atproto/identity": "^0.4.12",
    "@atproto/xrpc-server": "^0.6.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "archiver": "^7.0.1",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.10.0",
    "node-cron": "^4.2.1",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/autocannon": "^7.12.7",
    "@types/node": "^20.17.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.0",
    "autocannon": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AndrewNordstrom/bluesky-community-feed.git"
  },
  "homepage": "https://feed.corgi.network",
  "author": "Andrew Nordstrom",
  "license": "MIT",
  "keywords": [
    "bluesky",
    "atproto",
    "feed-generator",
    "community-governance",
    "algorithmic-transparency",
    "typescript"
  ]
}
