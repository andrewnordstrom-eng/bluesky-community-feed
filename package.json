{
  "name": "community-feed",
  "version": "1.2.0",
  "type": "module",
  "description": "A community-governed Bluesky feed generator where subscribers vote on algorithm parameters",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:lab-memory": "tsc -p tsconfig.lab-memory.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "migrate": "tsx scripts/migrate.ts",
    "stress": "tsx tests/stress/run.ts",
    "generate-feed-did": "tsx scripts/generate-feed-did.ts",
    "publish-feed": "tsx scripts/publish-feed.ts",
    "feed:birders-scout": "tsx scripts/birders-feed-scout.ts",
    "demo:capture-community-gov": "tsx scripts/demo-snapshot-capture.ts --manifest /tmp/corgi-community-gov-manifest.json --report /tmp/corgi-community-gov-report.json --review-sheet /tmp/corgi-community-gov-review.html",
    "demo:approve-community-gov": "tsx scripts/approve-demo-snapshot.ts",
    "test": "npm run sdk:build && vitest tests",
    "generate:component": "tsx scripts/generate-scoring-component.ts",
    "generate:route": "tsx scripts/generate-route.ts",
    "cli": "cd cli && npx tsx src/index.ts",
    "cli:build": "cd cli && tsc",
    "docs:verify": "node scripts/verify-docs.mjs",
    "seed-topics": "tsx scripts/seed-topics.ts",
    "backfill-topics": "tsx scripts/backfill-topics.ts",
    "sim:preflight": "tsx scripts/sim-preflight.ts",
    "sim:core": "vitest run --config vitest.harness.config.ts",
    "sim:campaign": "tsx scripts/sim-campaign.ts",
    "lab:jetstream-replay": "tsx scripts/jetstream-replay.ts",
    "lab:vote-load": "tsx scripts/vote-load.ts",
    "lab:memory-isolated": "tsx scripts/memory-isolated-stress.ts",
    "lab:memory-prod-parity": "npm run build:lab-memory && node dist-lab/scripts/memory-isolated-stress.js --prod-parity",
    "report:pdf": "python3 scripts/generate-report-pdf.py",
    "build:mcp-local": "if [ -f src/mcp-local/tsconfig.json ]; then cd src/mcp-local && npx tsc -p tsconfig.json; else echo 'src/mcp-local not present; skipping build:mcp-local'; fi",
    "sdk:build": "cd packages/feed-sdk && tsc -p tsconfig.json",
    "sdk:clean": "cd packages/feed-sdk && rm -rf dist",
    "sdk:fixture": "tsc -p tests/fixtures/example-external-component.tsconfig.json",
    "verify": "npm run build && npm test -- --run && npm run cli:build && npm run build:mcp-local && npm run sdk:build && npm run sdk:fixture && cd web && npm run lint && npm run build && cd ../web-next && npm run build",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "dependencies": {
    "@atproto/api": "^0.20.26",
    "@atproto/crypto": "^0.5.3",
    "@atproto/identity": "^0.5.4",
    "@atproto/xrpc-server": "^0.11.7",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "archiver": "^7.0.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "node-cron": "4.6.0",
    "pg": "^8.22.0",
    "pino": "^9.5.0",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0",
    "ws": "^8.20.1",
    "zod": "3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.4",
    "@testcontainers/redis": "12.0.4",
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.9.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.0",
    "fast-check": "4.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/andrewnordstrom-eng/bluesky-community-feed.git"
  },
  "homepage": "https://feed.corgi.network",
  "author": "Corgi Network",
  "license": "MIT",
  "keywords": [
    "bluesky",
    "atproto",
    "feed-generator",
    "community-governance",
    "algorithmic-transparency",
    "typescript"
  ],
  "overrides": {
    "ajv": "8.18.0",
    "@hono/node-server": "1.19.14",
    "hono": "4.12.27",
    "lodash": "4.18.1",
    "postcss": "8.5.13",
    "protobufjs": "7.6.4",
    "tar": "7.5.11",
    "vite": "8.0.16",
    "qs": "6.15.2",
    "ip-address": "10.1.1",
    "brace-expansion@5": "5.0.6"
  }
}
