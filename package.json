{
  "name": "community-feed",
  "version": "1.0.0",
  "type": "module",
  "description": "A community-governed Bluesky feed generator where subscribers vote on algorithm parameters",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "migrate": "tsx scripts/migrate.ts",
    "stress": "tsx tests/stress/run.ts",
    "generate-feed-did": "tsx scripts/generate-feed-did.ts",
    "publish-feed": "tsx scripts/publish-feed.ts",
    "test": "vitest",
    "generate:component": "tsx scripts/generate-scoring-component.ts",
    "generate:route": "tsx scripts/generate-route.ts",
    "cli": "cd cli && npx tsx src/index.ts",
    "cli:build": "cd cli && tsc",
    "docs:verify": "node scripts/verify-docs.mjs && node scripts/sanitize-receipts.mjs --check",
    "receipts:sanitize": "node scripts/sanitize-receipts.mjs",
    "receipts:verify": "node scripts/sanitize-receipts.mjs --check",
    "seed-topics": "tsx scripts/seed-topics.ts",
    "backfill-topics": "tsx scripts/backfill-topics.ts",
    "report:pdf": "python3 scripts/generate-report-pdf.py",
    "build:mcp-local": "if [ -f src/mcp-local/tsconfig.json ]; then cd src/mcp-local && npx tsc -p tsconfig.json; else echo 'src/mcp-local not present; skipping build:mcp-local'; fi",
    "verify": "npm run build && npm test -- --run && npm run cli:build && npm run build:mcp-local && cd web && npm run lint && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@atproto/api": "^0.19.13",
    "@atproto/crypto": "^0.4.0",
    "@atproto/identity": "^0.4.12",
    "@atproto/xrpc-server": "^0.10.20",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "archiver": "^7.0.1",
    "dotenv": "^16.4.0",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0",
    "ws": "^8.20.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/andrewnordstrom-eng/bluesky-community-feed.git"
  },
  "homepage": "https://feed.corgi.network",
  "author": "Andrew Nordstrom",
  "license": "MIT",
  "keywords": [
    "bluesky",
    "atproto",
    "feed-generator",
    "community-governance",
    "algorithmic-transparency",
    "typescript"
  ],
  "overrides": {
    "ajv": "8.18.0",
    "@hono/node-server": "1.19.14",
    "hono": "4.12.16",
    "lodash": "4.18.1",
    "postcss": "8.5.13",
    "protobufjs": "7.5.5",
    "tar": "7.5.11",
    "vite": "8.0.8"
  }
}
